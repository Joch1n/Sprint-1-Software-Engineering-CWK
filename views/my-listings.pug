extends layout

block content
  .container-advanced(style="margin-top: 40px;")
    // HEADER
    .hero-advanced(style="padding: 40px 20px;")
      .container-advanced
        .hero-content
          h1.hero-title My Food Listings
          p.hero-subtitle Manage and track all your shared food items
          
          a.btn-primary(href="/" style="display: inline-block; margin-top: 20px;")
            i.fas.fa-arrow-left(style="margin-right: 8px;")
            | Back Home

    // CREATE NEW LISTING CTA
    .stat-item(style="max-width: 500px; margin: 40px auto; background: var(--primary-color); color: white; padding: 30px; border-radius: 12px;")
      .stat-info(style="text-align: center;")
        h2(style="margin-bottom: 10px;") Share More Food
        p(style="margin-bottom: 20px;") Help reduce food waste by sharing surplus food with your community
        a.btn-secondary(href="#", style="display: inline-block; padding: 12px 30px;")
          i.fas.fa-plus(style="margin-right: 8px;")
          | Create New Listing

    // LISTINGS GRID
    .listings-section
      .food-grid
        .food-card-advanced
          .card-image-container
            img.card-image(src="https://images.unsplash.com/photo-1560806647-441ce23f6ef0?w=400&h=300&fit=crop", alt="Fresh Apples")
            .card-badges
              span.badge-category fruits
              span.badge-fresh Active

          .card-content
            h3.card-title Fresh Apples
            .rating
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star-half-alt
              span.rating-text 4.8 (12 reviews)

            p.card-description Crisp red apples from my garden. Harvested this morning, perfect for eating fresh or making juice!

            .card-meta
              .meta-item
                i.fas.fa-calendar
                span Posted 2 days ago
              .meta-item
                i.fas.fa-eye
                span 24 views
              .meta-item
                i.fas.fa-heart
                span 5 favorites

            .card-footer
              a.btn-view(href="/item/1", style="flex: 1;")
                i.fas.fa-eye(style="margin-right: 6px;")
                | View
              button.btn-favorite(style="padding: 10px 15px;", title="Edit")
                i.fas.fa-edit
              button.btn-favorite(style="padding: 10px 15px;", title="Delete")
                i.fas.fa-trash

        .food-card-advanced
          .card-image-container
            img.card-image(src="https://images.unsplash.com/photo-1509440159596-0249088772ff?w=400&h=300&fit=crop", alt="Homemade Bread")
            .card-badges
              span.badge-category baked
              span.badge-fresh Active

          .card-content
            h3.card-title Homemade Bread
            .rating
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              span.rating-text 5 (28 reviews)

            p.card-description Freshly baked sourdough bread, still warm from the oven. Made with organic flour and natural starter.

            .card-meta
              .meta-item
                i.fas.fa-calendar
                span Posted 1 day ago
              .meta-item
                i.fas.fa-eye
                span 45 views
              .meta-item
                i.fas.fa-heart
                span 8 favorites

            .card-footer
              a.btn-view(href="/item/2", style="flex: 1;")
                i.fas.fa-eye(style="margin-right: 6px;")
                | View
              button.btn-favorite(style="padding: 10px 15px;", title="Edit")
                i.fas.fa-edit
              button.btn-favorite(style="padding: 10px 15px;", title="Delete")
                i.fas.fa-trash

        .food-card-advanced
          .card-image-container
            img.card-image(src="https://images.unsplash.com/photo-1571781926596-2657ed051abb?w=400&h=300&fit=crop", alt="Organic Tomatoes")
            .card-badges
              span.badge-category vegetables
              span.badge-fresh Active

          .card-content
            h3.card-title Organic Tomatoes
            .rating
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star
              i.fas.fa-star-half-alt
              span.rating-text 4.8 (19 reviews)

            p.card-description Juicy vine-ripened tomatoes from greenhouse. Perfect for salads or cooking. Limited quantity available.

            .card-meta
              .meta-item
                i.fas.fa-calendar
                span Posted 3 days ago
              .meta-item
                i.fas.fa-eye
                span 18 views
              .meta-item
                i.fas.fa-heart
                span 2 favorites

            .card-footer
              a.btn-view(href="/item/3", style="flex: 1;")
                i.fas.fa-eye(style="margin-right: 6px;")
                | View
              button.btn-favorite(style="padding: 10px 15px;", title="Edit")
                i.fas.fa-edit
              button.btn-favorite(style="padding: 10px 15px;", title="Delete")
                i.fas.fa-trash

    // LISTING STATS
    .stats-bar(style="margin-top: 40px;")
      .stat-item
        i.fas.fa-box
        .stat-info
          .stat-number 12
          .stat-label Total Listings
      .stat-item
        i.fas.fa-eye
        .stat-info
          .stat-number 437
          .stat-label Total Views
      .stat-item
        i.fas.fa-check-circle
        .stat-info
          .stat-number 8
          .stat-label Completed

        i.fas.fa-inbox
        h3 No Listings Yet
        p You haven't shared any food yet. Start now!
        button.btn-primary#createFirstListing
          i.fas.fa-plus
          | Create Your First Listing

    // Create Listing Modal
    #listingModal.modal(style="display: none;")
      .modal-content
        .modal-header
          h2 Create New Listing
          button.modal-close(type="button") ×
        
        .modal-body
          form#listingForm
            .form-group
              label(for="foodName") Food Name *
              input#foodName.form-input(type="text", required, placeholder="e.g., Fresh Apples")
            
            .form-group
              label(for="category") Category *
              select#category.form-input(required)
                option(value="") Select Category
                option(value="vegetables") 🥬 Vegetables
                option(value="fruits") 🍎 Fruits
                option(value="baked") 🍞 Baked Goods
                option(value="prepared") 🍲 Prepared Meals
                option(value="dairy") 🥛 Dairy
                option(value="other") Other
            
            .form-group
              label(for="description") Description *
              textarea#description.form-input(rows="4", required, placeholder="Describe your food...")
            
            .form-group
              label(for="postcode") Postcode *
              input#postcode.form-input(type="text", required, placeholder="e.g., SW1A 1AA")
            
            .form-group
              label(for="quantity") Quantity
              input#quantity.form-input(type="text", placeholder="e.g., 1 basket")
            
            .form-group
              label(for="expiryDate") Expiry Date
              input#expiryDate.form-input(type="date")
            
            .form-actions
              button.btn-primary(type="submit")
                i.fas.fa-check
                | Create Listing
              button.btn-secondary(type="button")#cancelListing
                | Cancel

style
  .page-header {
    margin-bottom: 30px;
  }

  .page-header h1 {
    font-size: 32px;
    font-weight: bold;
    margin-bottom: 5px;
    color: #2c3e50;
  }

  .page-header p {
    color: #7f8c8d;
    font-size: 16px;
  }

  .manage-actions {
    display: flex;
    gap: 15px;
    margin-bottom: 30px;
  }

  .listings-table {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .table-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 15px;
    padding: 20px;
    background: #f8f9fa;
    font-weight: 600;
    color: #2c3e50;
    border-bottom: 2px solid #ecf0f1;
  }

  .table-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 15px;
    padding: 20px;
    border-bottom: 1px solid #ecf0f1;
    align-items: center;
    transition: background 0.3s;
  }

  .table-row:hover {
    background: #f8f9fa;
  }

  .item-name {
    font-weight: 600;
    color: #2c3e50;
  }

  .item-desc {
    font-size: 13px;
    color: #7f8c8d;
    margin-top: 5px;
  }

  .badge-category {
    display: inline-block;
    background: #2ecc71;
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }

  .status-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }

  .status-available {
    background: #d4edda;
    color: #155724;
  }

  .status-claimed {
    background: #fff3cd;
    color: #856404;
  }

  .status-expired {
    background: #f8d7da;
    color: #721c24;
  }

  .col-actions {
    display: flex;
    gap: 8px;
  }

  .action-btn {
    padding: 8px 12px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: all 0.3s;
    text-decoration: none;
  }

  .edit-btn {
    background: #3498db;
    color: white;
  }

  .edit-btn:hover {
    background: #2980b9;
  }

  .delete-btn {
    background: #e74c3c;
    color: white;
  }

  .delete-btn:hover {
    background: #c0392b;
  }

  /* Modal Styles */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
  }

  .modal-content {
    background: white;
    border-radius: 12px;
    width: 90%;
    max-width: 500px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid #ecf0f1;
  }

  .modal-header h2 {
    margin: 0;
    color: #2c3e50;
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: #7f8c8d;
  }

  .modal-body {
    padding: 20px;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #2c3e50;
  }

  .form-input {
    width: 100%;
    padding: 12px;
    border: 1px solid #ecf0f1;
    border-radius: 6px;
    font-size: 14px;
    transition: border-color 0.3s;
  }

  .form-input:focus {
    outline: none;
    border-color: #2ecc71;
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 25px;
  }

  .form-actions button {
    flex: 1;
  }

  @media (max-width: 768px) {
    .manage-actions {
      flex-direction: column;
    }

    .table-header,
    .table-row {
      grid-template-columns: 1fr;
    }

    .table-header {
      display: none;
    }

    .table-row {
      padding: 20px;
      border: 2px solid #ecf0f1;
      border-radius: 8px;
      margin-bottom: 10px;
    }

    .col-name::before {
      content: 'Food: ';
      font-weight: bold;
      display: block;
      margin-bottom: 5px;
    }
  }
