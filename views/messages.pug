extends layout

block content
  .hero-advanced
    .hero-content
      h1.hero-title Messages
      p.hero-tagline Arrange collection with your community
      p.hero-subtitle Conversations are linked to food listings.

  .container-advanced(style="padding-top: 30px;")
    if error
      p(style="color: #c0392b; margin-bottom: 16px; font-weight: 600;")= error

    if conversations.length === 0
      .empty-state
        h3 No messages yet
        p Message a sharer from an item page to start a conversation.
        a.btn-primary(href="/foodlistings") Browse Listings
    else
      div(style="display: grid; grid-template-columns: minmax(260px, 360px) 1fr; gap: 24px; align-items: start;")
        .food-card-advanced
          .card-content
            h3.card-title Conversations
            each conversation in conversations
              a.listing(href=`/messages/${conversation.listing_id}/${conversation.other_user_id}`, style="display: block; color: inherit; text-decoration: none;")
                strong #{conversation.other_username}
                p(style="margin: 4px 0; color: var(--text-light);") #{conversation.food_name || "Food listing"}
                p(style="margin: 0; color: var(--text-light);") #{conversation.last_message}

        .food-card-advanced
          .card-content
            if activeConversation
              h3.card-title #{activeConversation.foodName}
              p.card-description Conversation with #{activeConversation.otherUsername}

              if thread.length === 0
                p.card-description No messages in this conversation yet.
              else
                each message in thread
                  .listing(style=message.sender_id === user.id ? "background: #fff8f3;" : "background: #f8f9fa;")
                    strong= message.sender_id === user.id ? "You" : message.sender_username
                    span.rating-text  #{message.created_at.toISOString().slice(0, 16).replace("T", " ")}
                    p= message.message

              form.auth-form(method="POST", action=`/messages/${activeConversation.listingId}/${activeConversation.otherUserId}`, style="margin-top: 20px;")
                .form-group
                  label(for="message") Reply
                  textarea.form-input(id="message", name="message", rows="4", required)
                button.btn-primary(type="submit") Send Reply
            else
              h3.card-title Select a conversation
              p.card-description Choose a message thread to reply.
