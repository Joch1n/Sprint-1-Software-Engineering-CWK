block content
  style.
    .auth-container {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: #f8f9fa;
    }

    .auth-box {
      background: white;
      padding: 50px 40px;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      width: 100%;
      max-width: 400px;
    }

    .auth-form {
      margin-bottom: 30px;
    }

    .form-group {
      margin-bottom: 24px;
    }

    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: #2c3e50;
      font-size: 14px;
    }

    .form-input {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #ecf0f1;
      border-radius: 8px;
      font-size: 15px;
    }

    .form-input:focus {
      outline: none;
      border-color: #2ecc71;
    }

    .form-options {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      font-size: 14px;
    }

    .remember-me {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #7f8c8d;
    }

    .forgot-password {
      color: #2ecc71;
      text-decoration: none;
      font-weight: 600;
    }

    .btn-submit {
      width: 100%;
      padding: 14px;
      background: #2ecc71;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-submit:hover {
      background: #27ae60;
    }

    .form-divider {
      text-align: center;
      margin: 24px 0;
      color: #7f8c8d;
    }

    .btn-social {
      width: 100%;
      padding: 12px;
      text-align: center;
      border: 2px solid #ecf0f1;
      border-radius: 8px;
      text-decoration: none;
      display: block;
      color: #2c3e50;
      font-weight: 600;
    }

    .auth-footer {
      text-align: center;
      margin-top: 20px;
      color: #7f8c8d;
    }

    .auth-link {
      color: #2ecc71;
      font-weight: 700;
      text-decoration: none;
    }

  .auth-container
    .auth-box
      .auth-header
        a.auth-logo(href="/")
          i.fas.fa-leaf
          | ZeroWaste Connect
        h1 Welcome Back
        p Sign in to start sharing

      if error
        p(style="color: #c0392b; margin-bottom: 16px; font-weight: 600;")= error

      form.auth-form(method="POST", action="/login")
        .form-group
          label(for="email") Email Address
          input#email.form-input(type="email", name="email", required)

        .form-group
          label(for="password") Password
          input#password.form-input(type="password", name="password", required)

        .form-options
          label.remember-me
            input(type="checkbox", name="remember")
            | Remember me
          a.forgot-password(href="#") Forgot password?

        button.btn-submit(type="submit") Sign In

        .form-divider
          span or

        p(style="font-size: 13px; color: #7f8c8d; text-align: center;") Demo login: sarah@example.com / password123

      .auth-footer
        p No account yet?
        a.auth-link(href="/signup") Create one now
