extends layout

block content
  .container-advanced(style="margin-top: 40px;")
    .hero-advanced(style="padding: 40px 20px; margin-bottom: 40px;")
      .container-advanced
        .hero-content
          h1.hero-title Account Settings
          p.hero-subtitle Manage your profile and preferences

    .settings-container(style="display: grid; grid-template-columns: 250px 1fr; gap: 40px;")
      // SIDEBAR
      .settings-sidebar(style="background: white; padding: 20px; border-radius: 12px; height: fit-content; box-shadow: var(--shadow);")
        a.settings-link(href="#profile", style="display: flex; align-items: center; gap: 12px; padding: 15px; border-radius: 8px; color: var(--text-dark); text-decoration: none; transition: all 0.3s; border-left: 3px solid transparent;")
          i.fas.fa-user
          | Profile
        
        a.settings-link(href="#password", style="display: flex; align-items: center; gap: 12px; padding: 15px; border-radius: 8px; color: var(--text-dark); text-decoration: none; transition: all 0.3s; border-left: 3px solid transparent;")
          i.fas.fa-lock
          | Password
        
        a.settings-link(href="#notifications", style="display: flex; align-items: center; gap: 12px; padding: 15px; border-radius: 8px; color: var(--text-dark); text-decoration: none; transition: all 0.3s; border-left: 3px solid transparent;")
          i.fas.fa-bell
          | Notifications
        
        a.settings-link(href="#privacy", style="display: flex; align-items: center; gap: 12px; padding: 15px; border-radius: 8px; color: var(--text-dark); text-decoration: none; transition: all 0.3s; border-left: 3px solid transparent;")
          i.fas.fa-shield-alt
          | Privacy
        
        a.settings-link(href="/logout", style="display: flex; align-items: center; gap: 12px; padding: 15px; border-radius: 8px; color: #e74c3c; text-decoration: none; transition: all 0.3s; border-left: 3px solid transparent;")
          i.fas.fa-sign-out-alt
          | Logout

      // CONTENT
      .settings-content(style="background: white; padding: 40px; border-radius: 12px; box-shadow: var(--shadow);")
        .settings-section#profile
          h2(style="margin-bottom: 30px; font-size: 24px;") Profile Information
          p(style="color: var(--text-light); margin-bottom: 30px;") Update your profile details and personal information

          form(style="display: flex; flex-direction: column; gap: 20px;")
            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") Full Name
              input(type="text", placeholder="Your full name", value="Sarah Johnson", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; transition: border-color 0.3s; width: 100%;")

            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") Email Address
              input(type="email", placeholder="your@email.com", value="sarah@example.com", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; transition: border-color 0.3s; width: 100%;")

            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") Bio
              textarea(rows="4", placeholder="Tell us about yourself...", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; transition: border-color 0.3s; width: 100%; font-family: inherit;") Passionate about reducing food waste and helping the community!

            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") Postcode
              input(type="text", placeholder="e.g., SW1A 1AA", value="SW1A 1AA", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; transition: border-color 0.3s; width: 100%;")

            .form-group(style="margin-top: 20px;")
              button.btn-primary(type="submit", style="padding: 14px 40px;")
                i.fas.fa-save(style="margin-right: 8px;")
                | Save Changes

        .settings-section#password(style="display: none;")
          h2(style="margin-bottom: 30px; font-size: 24px;") Change Password
          p(style="color: var(--text-light); margin-bottom: 30px;") Update your password regularly to keep your account secure

          form(style="display: flex; flex-direction: column; gap: 20px;")
            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") Current Password
              input(type="password", placeholder="Enter current password", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; width: 100%;")

            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") New Password
              input(type="password", placeholder="Enter new password", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; width: 100%;")

            .form-group
              label(style="display: block; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);") Confirm Password
              input(type="password", placeholder="Confirm new password", style="padding: 12px 16px; border: 2px solid var(--border-color); border-radius: 8px; font-size: 15px; width: 100%;")

            .form-group(style="margin-top: 20px;")
              button.btn-primary(type="submit", style="padding: 14px 40px;")
                i.fas.fa-lock(style="margin-right: 8px;")
                | Update Password

        .settings-section#notifications(style="display: none;")
          h2(style="margin-bottom: 30px; font-size: 24px;") Notification Preferences
          p(style="color: var(--text-light); margin-bottom: 30px;") Control how you receive notifications

          form(style="display: flex; flex-direction: column; gap: 20px;")
            .form-group(style="display: flex; align-items: center; gap: 15px;")
              input(type="checkbox", id="emailNotif", checked, style="width: 20px; height: 20px; cursor: pointer;")
              label(for="emailNotif", style="margin: 0; cursor: pointer;")
                strong Email Notifications
                br
                span(style="color: var(--text-light); font-size: 14px;") Get notified about new listings and messages

            .form-group(style="display: flex; align-items: center; gap: 15px;")
              input(type="checkbox", id="pushNotif", checked, style="width: 20px; height: 20px; cursor: pointer;")
              label(for="pushNotif", style="margin: 0; cursor: pointer;")
                strong Push Notifications
                br
                span(style="color: var(--text-light); font-size: 14px;") Receive instant alerts on your device

            .form-group(style="display: flex; align-items: center; gap: 15px;")
              input(type="checkbox", id="weeklyDigest", checked, style="width: 20px; height: 20px; cursor: pointer;")
              label(for="weeklyDigest", style="margin: 0; cursor: pointer;")
                strong Weekly Digest
                br
                span(style="color: var(--text-light); font-size: 14px;") Receive a summary of nearby listings

            .form-group(style="margin-top: 20px;")
              button.btn-primary(type="submit", style="padding: 14px 40px;")
                i.fas.fa-check(style="margin-right: 8px;")
                | Save Preferences

        .settings-section#privacy(style="display: none;")
          h2(style="margin-bottom: 30px; font-size: 24px;") Privacy Settings
          p(style="color: var(--text-light); margin-bottom: 30px;") Control your privacy and data sharing

          form(style="display: flex; flex-direction: column; gap: 20px;")
            .form-group(style="display: flex; align-items: center; gap: 15px;")
              input(type="checkbox", id="publicProfile", checked, style="width: 20px; height: 20px; cursor: pointer;")
              label(for="publicProfile", style="margin: 0; cursor: pointer;")
                strong Public Profile
                br
                span(style="color: var(--text-light); font-size: 14px;") Allow others to view your profile

            .form-group(style="display: flex; align-items: center; gap: 15px;")
              input(type="checkbox", id="showRating", checked, style="width: 20px; height: 20px; cursor: pointer;")
              label(for="showRating", style="margin: 0; cursor: pointer;")
                strong Show Rating
                br
                span(style="color: var(--text-light); font-size: 14px;") Display your community rating

            .form-group(style="display: flex; align-items: center; gap: 15px;")
              input(type="checkbox", id="shareData", style="width: 20px; height: 20px; cursor: pointer;")
              label(for="shareData", style="margin: 0; cursor: pointer;")
                strong Share Anonymous Data
                br
                span(style="color: var(--text-light); font-size: 14px;") Help us improve with anonymous usage data

            .form-group(style="margin-top: 20px;")
              button.btn-primary(type="submit", style="padding: 14px 40px;")
                i.fas.fa-shield-alt(style="margin-right: 8px;")
                | Save Privacy Settings

script.
  document.querySelectorAll('.settings-link').forEach(link => {
    link.addEventListener('click', (e) => {
      if (e.target.closest('a').href.includes('logout')) return;
      e.preventDefault();
      
      document.querySelectorAll('.settings-section').forEach(s => s.style.display = 'none');
      document.querySelectorAll('.settings-link').forEach(l => l.style.borderColor = 'transparent');
      
      const target = e.target.closest('a').getAttribute('href');
      document.querySelector(target).style.display = 'block';
      e.target.closest('a').style.borderColor = 'var(--primary-color)';
      e.target.closest('a').style.background = '#fff8f3';
    });
  });

  document.querySelector('.settings-link').style.borderColor = 'var(--primary-color)';
  document.querySelector('.settings-link').style.background = '#fff8f3';

              label New Password
              input(type="password", placeholder="Enter new password")

            .form-group
              label Confirm Password
              input(type="password", placeholder="Confirm new password")

            button.btn-primary(type="submit") Update Password

        .settings-section#notifications(style="display: none;")
          h2 Notification Preferences
          p Choose how you want to be notified

          .notification-item
            .notification-toggle
              label.toggle
                input(type="checkbox", checked)
                span.toggle-slider
              .toggle-info
                h4 Email Notifications
                p Get updates about food listings and messages

          .notification-item
            .notification-toggle
              label.toggle
                input(type="checkbox", checked)
                span.toggle-slider
              .toggle-info
                h4 Push Notifications
                p Receive push notifications on your device

          .notification-item
            .notification-toggle
              label.toggle
                input(type="checkbox")
                span.toggle-slider
              .toggle-info
                h4 Marketing Emails
                p Receive news and special offers

        .settings-section#privacy(style="display: none;")
          h2 Privacy & Security
          p Control who can see your information

          .privacy-item
            .privacy-toggle
              label.toggle
                input(type="checkbox", checked)
                span.toggle-slider
              .toggle-info
                h4 Public Profile
                p Allow others to see your profile

          .privacy-item
            .privacy-toggle
              label.toggle
                input(type="checkbox", checked)
                span.toggle-slider
              .toggle-info
                h4 Show Location
                p Display your location on listings

          button.btn-secondary Manage Data

        .settings-section#logout(style="display: none;")
          h2 Logout
          p Sign out of your account

          .logout-info
            p.warning ⚠️ You'll be logged out from all devices
            a.btn-danger(href="/logout") Logout

style
  .settings-header {
    margin-bottom: 40px;
  }

  .settings-header h1 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 8px;
    color: #2c3e50;
  }

  .settings-header p {
    color: #7f8c8d;
  }

  .settings-container {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 40px;
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .settings-sidebar {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 20px;
    border-bottom: 1px solid #ecf0f1;
  }

  .settings-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    color: #7f8c8d;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.3s;
  }

  .settings-link:hover {
    background: #f8f9fa;
    color: #2ecc71;
  }

  .settings-link.active {
    background: #e8f8f5;
    color: #2ecc71;
    font-weight: 600;
  }

  .settings-content {
    flex: 1;
  }

  .settings-section {
    margin-bottom: 40px;
  }

  .settings-section h2 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #2c3e50;
  }

  .settings-section > p {
    color: #7f8c8d;
    margin-bottom: 30px;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #2c3e50;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px;
    border: 2px solid #ecf0f1;
    border-radius: 8px;
    font-size: 14px;
    transition: border-color 0.3s;
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #2ecc71;
  }

  .notification-item,
  .privacy-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border: 1px solid #ecf0f1;
    border-radius: 8px;
    margin-bottom: 15px;
  }

  .toggle-info h4 {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 4px;
  }

  .toggle-info p {
    font-size: 13px;
    color: #7f8c8d;
  }

  .toggle {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 28px;
    cursor: pointer;
  }

  .toggle input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: 0.3s;
    border-radius: 28px;
  }

  .toggle-slider::before {
    position: absolute;
    content: "";
    height: 22px;
    width: 22px;
    left: 3px;
    bottom: 3px;
    background-color: white;
    transition: 0.3s;
    border-radius: 50%;
  }

  input:checked + .toggle-slider {
    background-color: #2ecc71;
  }

  input:checked + .toggle-slider::before {
    transform: translateX(22px);
  }

  .logout-info {
    background: #fff3cd;
    border: 1px solid #ffc107;
    padding: 20px;
    border-radius: 8px;
  }

  .warning {
    color: #856404;
    margin-bottom: 15px;
  }

  .btn-primary, .btn-secondary, .btn-danger {
    padding: 12px 28px;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-primary {
    background: #2ecc71;
    color: white;
  }

  .btn-primary:hover {
    background: #27ae60;
  }

  .btn-secondary {
    background: #ecf0f1;
    color: #2c3e50;
  }

  .btn-secondary:hover {
    background: #d5dbdb;
  }

  .btn-danger {
    background: #e74c3c;
    color: white;
  }

  .btn-danger:hover {
    background: #c0392b;
  }

  @media (max-width: 768px) {
    .settings-container {
      grid-template-columns: 1fr;
    }

    .settings-sidebar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      border-bottom: none;
      border-right: 1px solid #ecf0f1;
      padding-right: 20px;
    }
  }
